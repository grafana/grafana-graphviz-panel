digraph G {
  rankdir=LR;
  
  node [shape=box, style=filled, fillcolor=lightblue];
  
  Start [fillcolor=lightgreen];
  End [fillcolor=lightcoral];
  
  Start -> Process1 [label="Initialize"];
  Process1 -> Decision [label="Check Status"];
  Decision -> Process2 [label="Success"];
  Decision -> Error [label="Failure"];
  Process2 -> End [label="Complete"];
  Error -> Retry [label="Retry?"];
  Retry -> Process1 [label="Yes"];
  Retry -> End [label="No"];
}

