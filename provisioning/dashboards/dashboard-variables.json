      },
      "id": 2,
      "title": "Network status",
      "type": "grafana-graphviz-panel",
      "options": {
        "inputMode": "code",
        "dotDiagram": "digraph G {\n  label=\"Network environment: $environment\";\n  labelloc=\"t\";\n  fontsize=18;\n  rankdir=TB;\n  \n  LoadBalancer [label=\"LoadBalancer\", shape=diamond];\n  WebServer [label=\"WebServer\", shape=box];\n  AppServer [label=\"AppServer\", shape=box];\n  \n  LoadBalancer -> WebServer;\n  LoadBalancer -> AppServer;\n}",
        "layoutEngine": "dot",
        "rankDirection": "TB",
        "edgeOverrides": [
          {
            "id": "edge_override_1",
            "targetEdgeIds": ["LoadBalancer__to__WebServer", "LoadBalancer__to__AppServer"],
            "matchMode": "manual",
            "matchFieldName": "edge_id",
            "matchPattern": "${id}",
            "rules": [
              {
                "kind": "strokeWidth",
                "widthFieldName": "bandwidth_normalized"
              },
              {
                "kind": "strokeColor",
                "colorFieldName": "latency_ms",
                "thresholdId": "latency_threshold"
              },
              {
                "kind": "label",
                "labelTemplate": "${bandwidth_mbps} Mbps\\n${latency_ms}ms\\n${packet_loss}% loss"
              }
            ]
          }
        ],
        "nodeOverrides": [],
        "namedThresholds": [
          {
            "id": "latency_threshold",
            "name": "Latency Threshold",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 20
              },
              {
                "color": "red",
                "value": 50
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-testdata-datasource"
          },
          "refId": "A",
          "scenarioId": "csv_content",
