      "id": 1,
      "title": "Application server status",
      "type": "grafana-graphviz-panel",
      "options": {
        "inputMode": "code",
        "dotDiagram": "digraph G {\n  label=\"Server environment: $environment\";\n  labelloc=\"t\";\n  fontsize=20;\n  rankdir=LR;\n  \n  WebServer [label=\"Web Server\", shape=box];\n  AppServer [label=\"App Server\", shape=box];\n  Database [label=\"Database\", shape=cylinder];\n  Cache [label=\"Cache\", shape=ellipse];\n  \n  WebServer -> AppServer;\n  AppServer -> Database;\n  AppServer -> Cache;\n}",
        "layoutEngine": "dot",
        "rankDirection": "LR",
        "edgeOverrides": [],
        "nodeOverrides": [
          {
            "id": "node_override_1",
            "targetNodeIds": ["WebServer", "AppServer", "Database", "Cache"],
            "matchMode": "manual",
            "matchFieldName": "server",
            "matchPattern": "${id}",
            "rules": [
              {
                "kind": "fillColor",
                "colorFieldName": "status_value",
                "thresholdId": "status_threshold"
              },
              {
                "kind": "label",
                "labelTemplate": "${server}\\nCPU: ${cpu}%\\nMem: ${memory}%\\n${status}"
              }
            ]
          }
        ],
        "namedThresholds": [
          {
            "id": "status_threshold",
            "name": "Status Threshold",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "orange",
                "value": 75
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-testdata-datasource"
          },
          "refId": "A",
          "scenarioId": "csv_content",
          "csvContent": "environment,server,cpu,memory,status,status_value\nproduction,WebServer,25,45,healthy,25\nproduction,AppServer,35,52,healthy,35\nproduction,Database,42,58,healthy,42\nproduction,Cache,18,34,healthy,18\nstaging,WebServer,55,68,warning,68\nstaging,AppServer,62,75,warning,75\nstaging,Database,78,82,warning,82\nstaging,Cache,48,55,warning,55\ndevelopment,WebServer,88,92,critical,92\ndevelopment,AppServer,95,96,critical,96\ndevelopment,Database,91,94,critical,94\ndevelopment,Cache,85,89,critical,89",
          "hide": false
        }
      ],
      "transformations": [
        {
          "id": "filterByValue",
          "options": {
            "filters": [
              {
                "fieldName": "environment",
                "config": {
                  "id": "equal",
                  "options": {
                    "value": "$environment"
                  }
                }
              }
            ],
            "type": "include",
            "match": "all"
          }
        }
      ]
    },
    {
      "datasource": {
        "type": "grafana-testdata-datasource"
      },
      "gridPos": {
        "h": 12,
