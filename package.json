{
  "name": "grafana-graphviz-panel",
  "version": "0.0.1",
  "private": true,
  "author": "Grafana",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24.11.0"
  },
  "packageManager": "npm@11.6.1",
  "scripts": {
    "build": "webpack -c ./.config/webpack/webpack.config.ts --env production",
    "dev": "webpack -w -c ./.config/webpack/webpack.config.ts --env development",
    "test": "jest --watch --onlyChanged",
    "test:ci": "jest --coverage --passWithNoTests --maxWorkers 4",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --cache --ignore-path ./.gitignore --ext .js,.jsx,.ts,.tsx .",
    "lint:fix": "npm run lint -- --fix && prettier --write --list-different .",
    "check-licenses": "license-checker-evergreen --production --failOn 'GPL;LGPL;AGPL;CC-BY-NC'",
    "e2e": "docker compose --profile playwright up --abort-on-container-exit",
    "e2e:llm": "docker compose run --rm -e PW_REPORTER=list -e PW_WORKERS=1 playwright npx playwright test",
    "e2e:ui": "npx playwright test --ui",
    "server": "docker compose up --build",
    "sign": "npx --yes @grafana/sign-plugin@latest",
    "coverage": "npm run coverage:clean && npm run e2e && npm run test:ci && npm run coverage:merge-reports",
    "coverage:clean": "rm -rf coverage && rm -rf coverage-merged && rm -rf monocart-report && rm -rf playwright-report",
    "coverage:merge-reports": "node scripts/merge-coverage.js"
  },
  "devDependencies": {
    "@grafana/eslint-config": "^8.2.0",
    "@grafana/plugin-e2e": "^3.4.11",
    "@grafana/tsconfig": "^2.0.0",
    "@playwright/test": "^1.52.0",
    "@stylistic/eslint-plugin-ts": "^2.9.0",
    "@swc/core": "^1.3.90",
    "@swc/helpers": "^0.5.0",
    "@swc/jest": "^0.2.26",
    "@testing-library/jest-dom": "6.1.4",
    "@testing-library/react": "14.0.0",
    "@types/d3-selection": "^3.0.11",
    "@types/graphlib": "^2.1.12",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.8.7",
    "@types/testing-library__jest-dom": "5.14.8",
    "@typescript-eslint/eslint-plugin": "^8.3.0",
    "@typescript-eslint/parser": "^8.3.0",
    "copy-webpack-plugin": "^11.0.0",
    "css-loader": "^6.7.3",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-jsdoc": "^46.8.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-webpack-plugin": "^4.0.1",
    "fork-ts-checker-webpack-plugin": "^8.0.0",
    "glob": "^10.2.7",
    "identity-obj-proxy": "3.0.0",
    "imports-loader": "^5.0.0",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.5.0",
    "jest-monocart-coverage": "^1.1.1",
    "license-checker-evergreen": "^6.2.0",
    "monocart-reporter": "2.9.21",
    "prettier": "^2.8.7",
    "replace-in-file-webpack-plugin": "^1.0.6",
    "sass": "1.63.2",
    "sass-loader": "13.3.1",
    "semver": "^7.6.3",
    "style-loader": "3.3.3",
    "swc-loader": "^0.2.3",
    "terser-webpack-plugin": "^5.3.10",
    "ts-node": "^10.9.2",
    "typescript": "5.5.4",
    "webpack": "^5.94.0",
    "webpack-cli": "^5.1.4",
    "webpack-livereload-plugin": "^3.0.2",
    "webpack-subresource-integrity": "^5.1.0",
    "webpack-virtual-modules": "^0.6.2"
  },
  "dependencies": {
    "@emotion/css": "11.10.6",
    "@grafana/assistant": "^0.1.7",
    "@grafana/data": "^12.2.0",
    "@grafana/i18n": "^12.2.0",
    "@grafana/runtime": "^12.2.0",
    "@grafana/schema": "^12.2.0",
    "@grafana/ui": "^12.2.0",
    "@hpcc-js/wasm": "^2.26.2",
    "d3-selection": "^3.0.0",
    "graphlib": "^2.1.8",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "ts-graphviz": "^3.0.7"
  }
}
